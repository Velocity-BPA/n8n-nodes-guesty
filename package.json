{
  "name": "n8n-nodes-guesty",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Guesty property management platform providing 10 resources and 56+ operations for listings, reservations, guest communication, calendar management, tasks, and automation workflows.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-guesty.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-guesty#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-guesty/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "guesty",
    "property-management",
    "vacation-rental",
    "short-term-rental",
    "airbnb",
    "booking",
    "hospitality",
    "automation",
    "workflow"
  ],
  "main": "dist/nodes/Guesty/Guesty.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GuestyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Guesty/Guesty.node.js",
      "dist/nodes/Guesty/GuestyTrigger.node.js"
    ]
  },
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}